      "name": "Extract from File"
    },
    {
      "parameters": {
        "jsCode": "const text = ($json.text || \"\").replace(/\\s+/g,' ').trim();\n\nconst chunkSize = 1500;\nconst overlap = 200;\n\nlet chunks = [];\n\nfor (let i = 0; i < text.length; i += (chunkSize - overlap)) {\n  chunks.push(text.slice(i, i + chunkSize));\n}\n\nreturn chunks.map((c, i) => ({\n  json: {\n    chunk: c,\n    chunk_id: i,\n    source: $('Read/Write Files from Disk').first().json.fileName || 'unknown'\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        768,
        48
      ],
      "id": "90a098d0-70ce-4822-8c0d-41d3a9704c16",
      "name": "Chunk"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/embeddings",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer 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"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"text-embedding-3-small\",\n  \"input\":  {{$items(\"Chunk\").map(item => item.json.chunk).toJsonString()}}\n}\n\n",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        336,
        272
      ],
      "id": "77f4dc28-ea61-4fd5-9e9c-3d509a1e1c4a",
      "name": "Chunk Embedding"
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map(item => ({\n  json: {\n    ...item.json,\n    chunk: (item.json.chunk || \"\")\n      .replace(/\\n/g, \" \")\n      .replace(/\\s+/g, \" \")\n      .trim()\n  }\n}));\n\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        992,
        48
      ],
      "id": "07310a4d-b56c-4fc7-889c-db9b8560c085",
