      "name": "Format Embedding"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://qdrant:6333/collections/pdf_docs/points/search",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"vector\": [{{$json.embedding}}],\n  \"limit\": 15,\n  \"with_payload\": true\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        960,
        -368
      ],
      "id": "351a3002-8c60-4172-8ec2-ee0575d170bc",
      "name": "Search Top-K in Qdrant"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.first().json.result;\nconst query = $('get Question').first().json.question;\nconst topk = 3;\nconst threshold = 0.7;\n// Step 1: clean + sort\nconst cleaned = items.map(item => {\n  const text = (item.payload?.text || '')\n    .replace(/[^\\x00-\\x7F]/g, '')\n    .replace(/\\s+/g, ' ')\n    .trim();\n\n  return {\n    id: item.id,\n    score: item.score,\n    text\n  };\n}).sort((a, b) => b.score - a.score);\n\n// Step 2: build context (join all text)\n// const context = cleaned\n//   .map(item => item.text)\n//   .filter(t => t.length > 0)\n//   .join('\\n\\n');\n\nconst context = cleaned\n  .filter(item => item.score > threshold)   // Step 1: filter by score\n  .slice(0, topk)                        // Step 2: take top 3\n  .map(item => item.text)             // Step 3: extract text\n  .join('\\n\\n');                      // Step 4: build context\n\n\n// Step 3: return prompt\nreturn [{\n  json: {\n    prompt: `You are a professional in green campus. Answer strictly based on the provided context.\n\nContext:\n${context}\n\nQuestion:\n${query}\n\nInstructions:\n- Use only the context\n- If answer not found, say \"Not found in document\"\n- Be concise and precise`\n  }\n}];\n\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        304,
        -160
      ],
      "id": "1eb8fc29-d88b-431d-8c89-aea3d22b899c",
      "name": "Generate Prompt"
    },
    {
      "parameters": {
        "jsCode": "const rawPrompt = $json.prompt || \"\";\n\n// Step 1: remove problematic Unicode/control chars (optional)\nconst cleaned = rawPrompt\n  .replace(/[^\\x00-\\x7F]/g, '')   // remove non-ASCII (optional)\n  .replace(/\\r/g, '')             // remove carriage return\n\n// Step 2: escape for JSON (CRITICAL)\nconst safePrompt = cleaned\n  .replace(/\\n/g, '\\\\n')          // escape newline\n  .replace(/\"/g, '\\\\\"');          // escape quotes\n\nreturn [{\n  json: {\n    prompt: safePrompt\n  }\n}];\n\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        512,
        -160
      ],
      "id": "e80912c2-9ad3-4777-a1eb-1a2cdf90ea94",
      "name": "Remove Unicode"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Authorization",
              "value": "Bearer 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"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"temperature\": 0.3,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an academic assistant that provides precise answers and generates concise, well-structured summaries based strictly on the given context. Do not add information outside the context.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Based on the context below, provide:\\n1) A concise answer\\n2) A short summary (3-5 sentences)\\n\\nContext:\\n{{ $json.prompt }}\"\n    }\n  ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        736,
        -160
      ],
      "id": "31cc772f-d75d-4f99-85e7-d3c63447c413",
      "name": "Generate Response"
    },
    {
      "parameters": {
        "jsCode": "return {\n  output: $input.first().json.choices[0].message.content\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        944,
        -160
      ],
      "id": "b6b855e7-ad3c-4ef6-b5e0-e40cedcb5dff",
      "name": "Filter the response"
    },
    {
      "parameters": {
        "jsCode": "const chunks = $('Chunk').all();\n\nreturn items.map((item, index) => {\n  return {\n    json: {\n      chunk_id: chunks[index].json.chunk_id,\n      text: chunks[index].json.chunk,\n      embedding: item.json.data[0].embedding\n    }\n  };\n});\n\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        272
      ],
      "id": "ccc6adb7-0c4c-414b-82d8-a4ff6af30e8d",
      "name": "PrepareData"
    },
    {
      "parameters": {
        "jsCode": "function uuid() {\n  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {\n    const r = Math.random() * 16 | 0;\n    const v = c === 'x' ? r : (r & 0x3 | 0x8);\n    return v.toString(16);\n  });\n}\n\nconst points = items.map(item => {\n  const embedding = item.json.embedding || item.json.data?.[0]?.embedding;\n\n  if (!embedding || embedding.length !== 1536) {\n    throw new Error(\"Invalid embedding detected\");\n  }\n\n  return {\n    id: uuid(),\n    vector: embedding,\n    payload: {\n      text: item.json.text\n    }\n  };\n});\n\nreturn [{ json: { points } }];\n\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        816,
        272
      ],
      "id": "f55e8e5f-6865-4549-aec7-160affa92e58",
      "name": "Data Restruction"
    },
